{
	"layer": "top",
	"position": "top",
	"height": 30,
	"margin-bottom": 6,
	"modules-left": ["hyprland/workspaces", "custom/spaceright", "hyprland/window"],
	"modules-right": [ "network", "cpu", "memory", "pulseaudio", "battery", "clock", "tray"],


	"hyprland/workspaces": {
		"format": "{icon}",
		"format-icons": {
			"1": "≤░Ον",
			"2": "≤░Οπ",
			"3": "≤░Ος",
			"4": "≤░Οφ",
			"5": "≤░Ο▒",
			"6": "≤░Ο│",
			"7": "≤░Ο╢",
			"8": "≤░Ο╣",
			"9": "≤░Ο╝",
		},
	},

	"custom/spaceright":{
		"tooltip": false,
		"format": "ΎΒΦ",
	},

	"network": {
		"tooltip": false,
		"interval": 2,
		"format": "ΎΑβ {bandwidthDownBytes} ΎΓΥ {bandwidthUpBytes}",
	},

	"cpu": {
		"tooltip": false,
		"interval": 15,
		"format": "ΎΜδ {}%",
	},

	"memory": {
		"tooltip": false,
		"interval": 30,
		"format": "ΎΔΚ {}%",
	},

	"pulseaudio": {
		"tooltip": false,
		"scroll-step": 5,
		"format": "{icon} {volume}%",
		"format-muted": "≤░ζθ {volume}%",
		"on-click":"pactl set-sink-mute @DEFAULT_SINK@ toggle",
		"format-icons": {
			"default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
		},
	},

	"battery": {
		"tooltip": false,
		"states": {
			"good": 95,
			"warning": 30,
			"critical": 20
		},
		"format": "{icon} {capacity}%",
		"format-charging": "ΎΘο {capacity}%",
		"format-plugged": "ΎΘο {capacity}%",
		"format-alt": "{time} {icon}",
		"format-icons": ["ΎΚΕ ", "ΎΚΔ ", "ΎΚΓ ", "ΎΚΒ ", "ΎΚΑ "],
	},

	"clock": {
		"tooltip": false,
		"format": "{:ΎΑΩ %I:%M %p  Ός░ %d/%m/%Y}",
	},

	"tray": {
		"icon-size": 18,
		"spacing": 10,
		"reverse-direction": true
	},
}
