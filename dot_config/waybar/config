{
	"layer": "top",
	"modules-left": ["custom/launcher", "cpu", "memory", "network"],
	"modules-center": ["hyprland/workspaces"],
	"modules-right": ["custom/wallpaper", "backlight", "pulseaudio", "battery", "clock", "tray"],

	"cpu": {
		"interval": 15,
		"format": "пЛЫ {}%",
		"max-length": 10
	},

	"memory": {
		"interval": 30,
		"format": "пГЙ {}%",
		"max-length": 10
	},

	"network": {
		"tooltip": false,
		"format-wifi": "пЗЂ  {essid}",
		"format-ethernet": ""
	},

	"tray": {
		"icon-size":18,
		"spacing": 10,
		"reverse-direction": true
	},
	
	"backlight": {
		"format": "{icon} {percent}%",
		"format-icons": ["оОН", "оПУ", "оПС", "оПП", "оПО", "оПН", "оПК", "оПИ", "оОЫ"]
	},

	"pulseaudio": {
		"tooltip": false,
		"scroll-step": 5,
		"format": "{icon} {volume}%",
		"format-muted": "{icon} {volume}%",
		"on-click":"pactl set-sink-mute @DEFAULT_SINK@ toggle",
		"format-icons": {
			"default": ["пА¶", "пАІ", "пА®"]
		}
	},

	"battery": {
		"states": {
			"good": 95,
			"warning": 30,
			"critical": 20
		},
		"format": "{icon}  {capacity}%",
		"format-charging": "пЗ¶ {capacity}%",
		"format-plugged": "пЗ¶ {capacity}%",
		"format-alt": "{time} {icon}",
		"format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"]
	},

	"clock": {
		"format": "{:пАЧ %I:%M %p  о™∞ %d/%m/%Y}"
	},

	"custom/launcher": {
		"format": "пМГ ",
		"on-click": "rofi -show drun",
		"on-click-right": "killall rofi"
	},

	"custom/wallpaper": {
		"format":"пАЊ ",
		"on-click": "bash $HOME/.config/system-scripts/hyprland/wallpaper/pkill_wp.sh"
	}
}
